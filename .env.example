# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/resume_analyzer_db?retryWrites=true&w=majority&appName=Cluster0

# Google Gemini API Key (optional - app works without it)
# Get your key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS and redirects)
# Local: http://localhost:3000
# Production: https://your-vercel-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Server Port (default: 8080)
PORT=8080
